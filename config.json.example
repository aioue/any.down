{
  "email": "your-email@example.com",           // Your Any.do login email address
  "password": "your-password",                 // Your Any.do password (keep secure!)
  "save_raw_data": true,                       // Save full JSON task data to timestamped files
  "auto_export": true,                         // Automatically export without prompting user
  "text_wrap_width": 80,                       // Character width for wrapping titles and notes in markdown
  "rotate_client_id": false,                   // Generate a new random client ID on every run instead of reusing the
                                               // persisted one. Keeping this false (default) makes each run look like
                                               // the same device to Any.do, which reduces the chance of triggering
                                               // extra 2FA verification emails. Set to true only if you need to
                                               // simulate a fresh device for debugging purposes.
  "ntfy": {
    "enabled": false,                          // Enable ntfy.sh notifications
    "url": "https://ntfy.sh",                  // ntfy server URL (use https://ntfy.sh for public, or your self-hosted instance)
    "topic": "anydo-alerts",                   // Topic name (notifications sent to {url}/{topic})
    "token": null                              // Optional bearer token for authenticated topics (set to null for public topics)
  }
} 
